{
  "appId": "com.mamo.neurophysics",
  "appName": "NeuroPhysics",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "allowsLinkPreview": false,
    "backgroundColor": "#0b1121",
    "scrollEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#0b1121",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0b1121",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  }
}
