    {
      "id": "suvat-v2",
      "name": "v² = u² + 2as",
      "canonical": "v² = u² + 2as",
      "tex": "v^2 = u^2 + 2as",
      "color": "blue",
      "variables": [
        { "symbol": "v", "name": "Final velocity",   "unit": "m/s"  },
        { "symbol": "u", "name": "Initial velocity", "unit": "m/s"  },
        { "symbol": "a", "name": "Acceleration",     "unit": "m/s²" },
        { "symbol": "s", "name": "Displacement",     "unit": "m"    }
      ],
      "rearrangements": [
        { "solveFor": "v", "formula": "v = √(u² + 2as)", "tex": "v = \\sqrt{u^2 + 2as}" },
        { "solveFor": "u", "formula": "u = √(v² − 2as)", "tex": "u = \\sqrt{v^2 - 2as}" },
        { "solveFor": "a", "formula": "a = (v² − u²) / 2s", "tex": "a = \\frac{v^2 - u^2}{2s}" },
        { "solveFor": "s", "formula": "s = (v² − u²) / 2a", "tex": "s = \\frac{v^2 - u^2}{2a}" }
      ],
      "onFormulaSheet": { "aqa": true, "edexcel": true, "ocr-gateway": false, "ocr-21c": false, "wjec": true },
