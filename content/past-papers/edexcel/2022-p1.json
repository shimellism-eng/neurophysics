          { "mark": 1, "description": "Wet road reduces friction between tyres and road" },
          { "mark": 2, "description": "Reduced friction means a smaller braking force" },
          { "mark": 3, "description": "Smaller braking force means the car decelerates more slowly" },
          { "mark": 4, "description": "Therefore braking distance (and total stopping distance) is greater" }
        ],
