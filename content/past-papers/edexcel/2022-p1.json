      "questionText": "A 1500 kg car starts from rest and reaches a speed of 24 m/s in 8.0 seconds. Calculate: (i) the acceleration, (ii) the resultant force.",
      "markScheme": {
        "answer": "4500 N",
        "unit": "N",
        "steps": [
          { "mark": 1, "description": "a = (v - u) / t = (24 - 0) / 8.0" },
          { "mark": 2, "description": "a = 3.0 m/s\u00b2" },
          { "mark": 3, "description": "Recalls F = ma" },
          { "mark": 4, "description": "F = 1500 \u00d7 3.0" },
          { "mark": 5, "description": "Correct answer: 4500 N" }
        ],
        "allowedAlternatives": ["4.5 kN"],
        "commonErrors": [
          "Using 24 as acceleration without dividing by time",
          "Arithmetic errors in multiplication"
        ]
      },
      "usedAsWorkedExample": true,
      "usedAsYourTurn": false
