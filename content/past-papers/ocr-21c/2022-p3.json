    {
      "id": "ocr-21c-2022-p3-q2b",
      "number": "2(b)",
      "topic": "forces",
      "concept": "newtons-second-law",
      "marks": 5,
      "type": "calculation",
      "difficulty": "hard",
      "higherOnly": false,
      "questionText": "A lift has a mass of 600 kg. It accelerates upwards at 1.5 m/s\u00b2. Gravitational field strength g = 10 N/kg. Calculate the tension in the cable pulling the lift upwards.",
      "markScheme": {
        "answer": "6900 N",
        "unit": "N",
        "steps": [
          { "mark": 1, "description": "Weight of lift = 600 \u00d7 10 = 6000 N" },
          { "mark": 2, "description": "Resultant force needed = ma = 600 \u00d7 1.5 = 900 N (upwards)" },
          { "mark": 3, "description": "Tension - Weight = Resultant force" },
          { "mark": 4, "description": "T = 6000 + 900" },
          { "mark": 5, "description": "Correct answer: 6900 N" }
        ],
        "allowedAlternatives": ["6.9 kN"],
        "commonErrors": [
          "Subtracting weight from resultant instead of adding",
          "Only calculating F = ma without considering weight"
        ]
      },
      "usedAsWorkedExample": true,
      "usedAsYourTurn": false
    },
    {
