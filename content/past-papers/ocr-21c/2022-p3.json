      "type": "calculation",
      "difficulty": "easy",
      "higherOnly": false,
      "questionText": "A drone has four propellers each providing 2.5 N of upward thrust. The drone weighs 8.0 N. Calculate the resultant vertical force on the drone.",
      "markScheme": {
        "answer": "2.0 N upwards",
        "unit": "N",
        "steps": [
          { "mark": 1, "description": "Total thrust = 4 \u00d7 2.5 = 10.0 N" },
          { "mark": 2, "description": "Resultant = 10.0 - 8.0 = 2.0 N" },
          { "mark": 3, "description": "Direction: upwards" }
        ],
        "commonErrors": [
          "Using only one propeller's thrust",
          "Forgetting to subtract the weight"
        ]
      },
      "usedAsWorkedExample": false,
      "usedAsYourTurn": true
    },
