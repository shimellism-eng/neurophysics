      "marks": 4,
      "type": "calculation",
      "difficulty": "medium",
      "higherOnly": false,
      "questionText": "A bicycle and rider have a combined mass of 85 kg. The rider pedals with a driving force of 255 N. Friction is 85 N. Calculate the acceleration.",
      "markScheme": {
        "answer": "2.0 m/s\u00b2",
        "unit": "m/s\u00b2",
        "steps": [
          { "mark": 1, "description": "Resultant force = 255 - 85 = 170 N" },
          { "mark": 2, "description": "Recalls a = F/m" },
          { "mark": 3, "description": "Substitutes: a = 170 / 85" },
          { "mark": 4, "description": "Correct answer: 2.0 m/s\u00b2" }
        ],
        "commonErrors": [
          "Not subtracting friction first",
          "Using 255 N as the resultant force"
        ]
      },
      "usedAsWorkedExample": true,
      "usedAsYourTurn": false
    },
