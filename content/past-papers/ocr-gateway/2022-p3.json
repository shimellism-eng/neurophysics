      "questionText": "A 0.4 kg ball is dropped and hits the ground at 7 m/s. It bounces back up at 5 m/s. Calculate the change in momentum.",
      "markScheme": {
        "answer": "4.8 kg m/s (upwards)",
        "unit": "kg m/s",
        "steps": [
          { "mark": 1, "description": "Momentum before (downwards): 0.4 \u00d7 (-7) = -2.8 kg m/s" },
          { "mark": 2, "description": "Momentum after (upwards): 0.4 \u00d7 5 = 2.0 kg m/s" },
          { "mark": 3, "description": "Change = final - initial = 2.0 - (-2.8)" },
          { "mark": 4, "description": "Change in momentum = 4.8 kg m/s (upwards)" }
        ],
        "commonErrors": [
          "Not accounting for direction change",
          "Subtracting speeds instead of considering momentum with direction"
