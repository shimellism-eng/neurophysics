      "questionText": "A 3.0 kg toy car moving at 2.0 m/s collides with and sticks to a stationary 1.0 kg toy car. Calculate the velocity of the combined cars after the collision.",
      "markScheme": {
        "answer": "1.5 m/s",
        "unit": "m/s",
        "steps": [
          { "mark": 1, "description": "Momentum before = 3.0 \u00d7 2.0 = 6.0 kg m/s" },
          { "mark": 2, "description": "Stationary car momentum = 0" },
          { "mark": 3, "description": "Total momentum before = 6.0 kg m/s" },
          { "mark": 4, "description": "Combined mass = 4.0 kg; by conservation, 4.0 \u00d7 v = 6.0" },
          { "mark": 5, "description": "v = 6.0 / 4.0 = 1.5 m/s" }
        ],
        "commonErrors": [
