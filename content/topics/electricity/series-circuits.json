          "paper": 1,
          "questionNumber": "7(a)",
          "marks": 4,
          "questionText": "Two resistors of 6.0 Ω and 4.0 Ω are connected in series to a 20 V battery. Calculate: (i) the total resistance, (ii) the current in the circuit.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Find total resistance",
              "content": "Add the resistances:",
              "equation": "R_total = 6.0 + 4.0 = 10 Ω",
              "markSchemeNote": "1 mark: correct total resistance"
            },
            {
              "stepNum": 2,
              "label": "Find the current",
              "content": "Use I = V / R:",
              "equation": "I = 20 / 10 = 2.0 A",
              "markSchemeNote": "1 mark: rearrangement; 1 mark: substitution; 1 mark: correct answer + unit"
