          "source": "AQA 2023 Paper 1 · Q2(c)",
          "year": 2023,
          "paper": 1,
          "questionNumber": "2(c)",
          "marks": 3,
          "questionText": "A motor uses 500 J of energy. 350 J is transferred to useful kinetic energy. Calculate the efficiency of the motor. Give your answer as a percentage.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Write the equation",
              "content": "State the efficiency equation:",
              "equation": "efficiency = useful output / total input",
              "markSchemeNote": "1 mark: correct equation"
            },
            {
              "stepNum": 2,
              "label": "Substitute values",
              "content": "Useful output = 350 J, total input = 500 J:",
              "equation": "efficiency = 350 / 500 = 0.70",
              "markSchemeNote": "1 mark: correct substitution"
            },
            {
              "stepNum": 3,
              "label": "Convert to percentage",
              "content": "Multiply by 100:",
              "equation": "efficiency = 0.70 × 100 = 70%",
              "markSchemeNote": "1 mark: correct percentage"
