      "id": "diagnostic",
      "type": "diagnostic",
      "uiTag": "Misconception check",
      "uiColor": "red",
      "title": "Quick question first…",
      "question": "A spring is stretched by 2 cm, then stretched to 4 cm (double the extension). How does the elastic potential energy change?",
      "options": [
        "It doubles",
        "It quadruples",
        "It stays the same",
        "It halves"
      ],
      "correctIndex": 1,
      "misconceptionFeedback": "⚠️ Common misconception! Because extension is squared in Ee = ½ke², doubling the extension means the elastic PE is multiplied by 2² = 4. Extension has a much bigger effect than you might expect.",
      "correctFeedback": "✓ Correct! Because e is squared in the equation, doubling the extension quadruples the energy stored. This is the same squaring pattern as in kinetic energy (v²).",
      "bestSource": "BEST resource: AQA GCSE Physics specification 4.1.1.4: Elastic potential energy"
    },
    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "Elastic Potential Energy",
      "bodyHTML": "When a spring (or any elastic object) is <strong>stretched or compressed</strong>, energy is stored in its <strong>elastic potential energy store</strong>. This only applies within the <strong>limit of proportionality</strong> - if you stretch too far, the spring deforms permanently and the equation no longer applies. The energy depends on the <strong>spring constant</strong> (stiffness) and the <strong>extension</strong> (how much it has stretched).",
      "keyEquation": "Ee = ½ × k × e²",
      "diagram": {
        "type": "equation-breakdown",
        "variables": [
          {
            "symbol": "Ee",
            "label": "Elastic PE",
            "unit": "J",
            "color": "cyan"
          },
          {
            "symbol": "k",
            "label": "Spring constant",
            "unit": "N/m",
            "color": "purple"
          },
          {
            "symbol": "e",
            "label": "Extension",
            "unit": "m",
            "color": "amber"
          }
        ],
        "relationships": [
          "Bigger k (stiffer spring) → more Ee",
          "Bigger e → much more Ee (e is squared!)",
          "Only valid within the limit of proportionality"
        ]
      },
      "keyWords": [
        "elastic potential energy",
        "spring constant",
        "extension",
        "limit of proportionality",
        "Hooke’s Law"
      ],
      "commonErrors": [
        "Forgetting to square the extension",
        "Forgetting the ½ in the equation",
        "Not converting cm to m for extension",
        "Using the equation beyond the limit of proportionality"
      ],
      "keyEquationTex": "E_e = \\frac{1}{2}ke^2"
