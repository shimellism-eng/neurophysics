    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "Gravitational Potential Energy",
      "bodyHTML": "An object raised above the ground has energy in its <strong>gravitational potential energy (GPE) store</strong>. GPE depends on <strong>mass</strong>, <strong>gravitational field strength</strong> (g = 9.8 N/kg on Earth), and <strong>height</strong>. The higher or heavier the object, the more GPE it has. When it falls, GPE is transferred to the kinetic energy store.",
      "keyEquation": "Ep = m × g × h",
