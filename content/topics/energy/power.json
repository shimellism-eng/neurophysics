    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "Power",
      "bodyHTML": "<strong>Power</strong> is the <strong>rate</strong> of energy transfer, that is how fast energy is transferred or work is done. It is measured in <strong>watts (W)</strong>. One watt means one joule of energy transferred per second. A more powerful device transfers the same amount of energy in <strong>less time</strong>, or more energy in the same time.",
      "keyEquation": "P = E / t",
