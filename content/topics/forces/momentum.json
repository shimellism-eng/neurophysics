    {
      "id": "worked-example",
      "type": "worked",
      "uiTag": "Worked Example",
      "uiColor": "amber",
      "workedExamples": {
        "aqa": {
          "source": "AQA style · Momentum calculation + collision",
          "marks": 4,
          "questionText": "A car of mass 1500 kg travels at 20 m/s. Calculate its momentum. The car then collides with a stationary van of mass 2500 kg and they move together. Calculate their speed after collision.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Calculate car’s momentum",
              "content": "Use p = m × v:",
              "equation": "p = 1500 × 20 = 30 000 kg·m/s",
              "markSchemeNote": "1 mark: correct momentum calculation"
            },
            {
              "stepNum": 2,
              "label": "State conservation of momentum",
              "content": "Total momentum before = total momentum after. Van is stationary so its momentum = 0.",
              "equation": "30 000 = (1500 + 2500) × v",
              "markSchemeNote": "1 mark: conservation stated or implied"
            },
            {
              "stepNum": 3,
              "label": "Solve for v",
              "content": "Combined mass = 4000 kg:",
              "equation": "v = 30 000 / 4000 = 7.5 m/s",
              "markSchemeNote": "1 mark: correct rearrangement and substitution"
            },
            {
              "stepNum": 4,
              "label": "State answer with units",
              "content": "Always include the unit.",
              "equation": "v = 7.5 m/s ✓",
              "markSchemeNote": "1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "Momentum = 30 000 kg·m/s; speed after collision = 7.5 m/s",
          "finalAnswerUnit": "m/s",
          "totalMarks": 4
        },
        "edexcel": {
          "source": "Edexcel style · Momentum calculation",
          "marks": 3,
          "questionText": "A bullet of mass 0.01 kg travels at 400 m/s. Calculate its momentum.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Write the equation",
              "content": "State the momentum equation:",
              "equation": "p = m × v",
              "markSchemeNote": "1 mark: correct equation stated"
            },
            {
              "stepNum": 2,
              "label": "Substitute values",
              "content": "Put in the numbers:",
              "equation": "p = 0.01 × 400",
              "markSchemeNote": "1 mark: correct substitution"
            },
            {
              "stepNum": 3,
              "label": "Calculate and state units",
              "content": "Multiply:",
              "equation": "p = 4 kg·m/s ✓",
              "markSchemeNote": "1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "4 kg·m/s",
          "finalAnswerUnit": "kg·m/s",
          "totalMarks": 3
        },
        "ocr-gateway": {
          "source": "OCR Gateway style · Conservation of momentum",
          "marks": 3,
          "questionText": "A trolley of mass 2 kg moving at 3 m/s collides with a stationary trolley of mass 1 kg. They stick together. Find their velocity after collision.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Calculate total momentum before",
              "content": "Moving trolley: p = 2 × 3 = 6 kg·m/s. Stationary trolley: p = 0.",
              "equation": "Total momentum before = 6 kg·m/s",
              "markSchemeNote": "1 mark: correct momentum before"
            },
            {
              "stepNum": 2,
              "label": "Apply conservation",
              "content": "Total momentum after = total momentum before:",
              "equation": "6 = (2 + 1) × v = 3v",
              "markSchemeNote": "1 mark: conservation applied correctly"
            },
            {
              "stepNum": 3,
              "label": "Solve",
              "content": "Divide both sides by 3:",
              "equation": "v = 6 / 3 = 2 m/s ✓",
              "markSchemeNote": "1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "2 m/s",
          "finalAnswerUnit": "m/s",
          "totalMarks": 3
        },
        "ocr-21c": {
          "source": "OCR 21st Century style · Simple momentum",
          "marks": 2,
          "questionText": "Calculate the momentum of a 70 kg runner moving at 8 m/s.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Apply p = mv",
              "content": "All values given. Substitute straight in:",
              "equation": "p = 70 × 8 = 560 kg·m/s",
              "markSchemeNote": "1 mark: correct substitution; 1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "560 kg·m/s",
          "finalAnswerUnit": "kg·m/s",
          "totalMarks": 2
        },
        "wjec": {
          "source": "WJEC style · Change in momentum",
          "marks": 3,
          "questionText": "A 0.5 kg ball moving at 6 m/s hits a wall and bounces back at 4 m/s. Calculate the change in momentum.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Define direction and calculate momentum before",
              "content": "Take the initial direction as positive:",
              "equation": "p_before = 0.5 × 6 = 3 kg·m/s",
              "markSchemeNote": "1 mark: correct momentum before"
            },
            {
              "stepNum": 2,
              "label": "Calculate momentum after",
              "content": "Ball bounces back, so velocity is now negative:",
              "equation": "p_after = 0.5 × (−4) = −2 kg·m/s",
              "markSchemeNote": "1 mark: correct sign for reversed direction"
            },
            {
              "stepNum": 3,
              "label": "Find the change",
              "content": "Change = final − initial:",
              "equation": "Δp = −2 − 3 = −5 kg·m/s ✓",
              "markSchemeNote": "1 mark: correct change in momentum with sign and unit"
            }
          ],
          "finalAnswer": "−5 kg·m/s",
          "finalAnswerUnit": "kg·m/s",
          "totalMarks": 3
        }
      }
