    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "Newton’s Second Law",
      "bodyHTML": "The <strong>resultant force</strong> on an object equals its <strong>mass × acceleration</strong>. A bigger force → more acceleration. A bigger mass → less acceleration (for the same force). The force and acceleration always act in the <strong>same direction</strong>.",
      "keyEquation": "F = m × a",
