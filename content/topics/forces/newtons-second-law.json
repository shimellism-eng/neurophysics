      "workedExamples": {
        "aqa": {
          "source": "AQA 2023 Paper 2 · Q4(b)",
          "year": 2023,
          "paper": 2,
          "questionNumber": "4(b)",
          "marks": 4,
          "questionText": "A car of mass 1200 kg accelerates from rest to 18 m/s in 9.0 seconds. Calculate the resultant force acting on the car.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Identify the knowns",
              "content": "mass m = 1200 kg\nfinal velocity v = 18 m/s\ntime t = 9.0 s\ninitial velocity u = 0 m/s (from rest)",
              "equation": null,
              "markSchemeNote": null
            },
            {
              "stepNum": 2,
              "label": "Find acceleration",
              "content": "Use a = (v − u) / t",
              "equation": "a = (18 − 0) / 9.0 = 2.0 m/s²",
              "markSchemeNote": "1 mark: correct calculation of acceleration"
            },
            {
              "stepNum": 3,
              "label": "Apply F = ma",
              "content": "Substitute into Newton’s Second Law:",
              "equation": "F = 1200 × 2.0 = 2400 N",
              "markSchemeNote": "1 mark: correct substitution; 1 mark: correct answer"
            },
            {
              "stepNum": 4,
              "label": "State answer with units",
              "content": "Always write the unit - examiners award a mark for it.",
              "equation": "F = 2400 N ✓",
              "markSchemeNote": "1 mark: unit stated correctly"
            }
          ],
          "finalAnswer": "2400 N",
          "finalAnswerUnit": "N",
          "totalMarks": 4
        },
        "edexcel": {
          "source": "Edexcel 2023 Paper 1 · Q5(c)",
          "year": 2023,
          "paper": 1,
          "questionNumber": "5(c)",
          "marks": 3,
          "questionText": "A lorry has a mass of 8000 kg. The resultant force on the lorry is 12 000 N. Calculate the acceleration of the lorry.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Identify the knowns",
              "content": "mass m = 8000 kg\nresultant force F = 12 000 N",
              "equation": null,
              "markSchemeNote": null
            },
            {
              "stepNum": 2,
              "label": "Rearrange for acceleration",
              "content": "Divide both sides by m:",
              "equation": "a = F / m",
              "markSchemeNote": "1 mark: correct rearrangement"
            },
            {
              "stepNum": 3,
              "label": "Substitute and calculate",
              "content": "Put in the numbers:",
              "equation": "a = 12 000 / 8000 = 1.5 m/s²",
              "markSchemeNote": "1 mark: substitution; 1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "1.5 m/s²",
          "finalAnswerUnit": "m/s²",
          "totalMarks": 3
        },
