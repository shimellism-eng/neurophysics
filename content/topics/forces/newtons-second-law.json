          "questionNumber": "6(a)",
          "marks": 3,
          "questionText": "A motorcycle has a mass of 250 kg. The engine provides a driving force of 1500 N and the friction force is 500 N. Calculate the acceleration of the motorcycle.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Find the resultant force",
              "content": "Subtract opposing forces first:",
              "equation": "F_resultant = 1500 − 500 = 1000 N",
              "markSchemeNote": "1 mark: correct resultant force"
            },
            {
              "stepNum": 2,
              "label": "Apply a = F / m",
              "content": "Substitute into Newton’s Second Law:",
              "equation": "a = 1000 / 250 = 4.0 m/s²",
              "markSchemeNote": "1 mark: rearrangement; 1 mark: correct answer + unit"
            }
          ],
          "finalAnswer": "4.0 m/s²",
          "finalAnswerUnit": "m/s²",
          "totalMarks": 3
