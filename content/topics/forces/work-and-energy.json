          "questionText": "A person pushes a box with a force of 40 N over a distance of 8 m. Calculate the work done.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Write the equation",
              "content": "State the work done equation:",
              "equation": "W = F × d",
              "markSchemeNote": "1 mark: correct equation recalled"
            },
            {
              "stepNum": 2,
              "label": "Substitute the values",
              "content": "Force F = 40 N, distance d = 8 m:",
              "equation": "W = 40 × 8",
              "markSchemeNote": "1 mark: correct substitution"
            },
            {
              "stepNum": 3,
              "label": "Calculate with units",
              "content": "Multiply and state the unit:",
              "equation": "W = 320 J ✓",
