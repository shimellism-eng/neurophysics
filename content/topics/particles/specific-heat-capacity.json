          "questionText": "Calculate the energy needed to heat 2.0 kg of water from 20\u00b0C to 70\u00b0C. The specific heat capacity of water is 4200 J/kg\u00b0C.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Identify the knowns and find \u0394\u03b8",
              "content": "m = 2.0 kg\nc = 4200 J/kg\u00b0C\n\u0394\u03b8 = 70 \u2212 20 = 50\u00b0C",
              "equation": null,
              "markSchemeNote": "1 mark \u2014 correct temperature change (50\u00b0C)"
            },
            {
              "stepNum": 2,
              "label": "Write and apply the equation",
              "content": "Use E = mc\u0394\u03b8:",
              "equation": "E = 2.0 \u00d7 4200 \u00d7 50",
              "markSchemeNote": "1 mark \u2014 correct substitution"
            },
            {
              "stepNum": 3,
              "label": "Calculate",
              "content": "Multiply out:",
              "equation": "E = 420\u202f000 J = 4.2 \u00d7 10\u2075 J",
              "markSchemeNote": "1 mark \u2014 correct answer with unit"
            }
          ],
          "finalAnswer": "420\u202f000 J (4.2 \u00d7 10\u2075 J)",
