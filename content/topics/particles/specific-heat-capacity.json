    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "Specific Heat Capacity",
      "bodyHTML": "The <strong>specific heat capacity</strong> (c) of a substance is the energy required to raise the temperature of 1 kg of the substance by 1\u00b0C. The total energy transferred when heating a mass m by a temperature change \u0394\u03b8 is given by <strong>E = mc\u0394\u03b8</strong>. Water has a specific heat capacity of 4200 J/kg\u00b0C, which is very high \u2014 this makes it excellent for storing and transferring thermal energy.",
      "keyEquation": "E = m \u00d7 c \u00d7 \u0394\u03b8",
      "diagram": {
        "type": "equation-breakdown",
        "variables": [
          { "symbol": "E",      "label": "Energy change",         "unit": "J",      "color": "cyan"   },
          { "symbol": "m",      "label": "Mass",                  "unit": "kg",     "color": "purple" },
          { "symbol": "c",      "label": "Specific heat capacity","unit": "J/kg\u00b0C","color": "amber"  },
          { "symbol": "\u0394\u03b8", "label": "Temperature change",    "unit": "\u00b0C",    "color": "blue"   }
        ],
        "relationships": [
          "Bigger mass \u2192 more energy needed for same \u0394T",
          "Higher c \u2192 more energy needed per kg per \u00b0C",
          "Bigger \u0394\u03b8 \u2192 more energy needed",
          "Water: c = 4200 J/kg\u00b0C (very high)"
        ]
      },
      "keyWords": ["specific heat capacity", "energy", "mass", "temperature change", "joule", "J/kg\u00b0C"],
      "commonErrors": [
