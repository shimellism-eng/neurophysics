      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "The Electromagnetic Spectrum",
      "svgDiagram": "em-spectrum",
      "bodyHTML": "Electromagnetic (EM) waves are <strong>transverse</strong> waves that transfer energy. They all travel at the <strong>speed of light</strong> (3 × 10⁸ m/s) in a vacuum. The spectrum, in order of <strong>decreasing wavelength</strong> (increasing frequency), is: <strong>Radio, Microwave, Infrared, Visible light, Ultraviolet, X-rays, Gamma rays</strong>. EM waves do <strong>not</strong> need a medium - they can travel through a vacuum. Higher-frequency EM waves carry <strong>more energy</strong> and are more <strong>dangerous</strong>.",
      "keyEquation": "v = f × λ (where v = 3 × 10⁸ m/s for all EM waves in a vacuum)",
      "diagram": {
        "type": "comparison",
        "variables": [
          {
            "symbol": "R",
            "label": "Radio waves",
            "unit": "longest λ",
            "color": "cyan"
          },
          {
            "symbol": "V",
            "label": "Visible light",
            "unit": "mid-range",
            "color": "green"
          },
          {
            "symbol": "γ",
            "label": "Gamma rays",
            "unit": "shortest λ",
            "color": "pink"
          }
        ],
        "relationships": [
          "Radio → Microwave → Infrared → Visible → Ultraviolet → X-ray → Gamma",
          "Wavelength decreases left to right →",
          "Frequency and energy increase left to right →"
        ]
      },
      "keyWords": [
