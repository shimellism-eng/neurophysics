      "workedExamples": {
        "aqa": {
          "source": "AQA 2023 Paper 2 · Q8(a)",
          "year": 2023,
          "paper": 2,
          "questionNumber": "8(a)",
          "marks": 3,
          "questionText": "A radio station broadcasts at a frequency of 100 MHz. The speed of light is 3 × 10⁸ m/s. Calculate the wavelength of the radio wave.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Convert units",
              "content": "100 MHz = 100 × 10⁶ Hz = 1 × 10⁸ Hz",
              "equation": null,
              "markSchemeNote": "1 mark: correct conversion"
            },
            {
              "stepNum": 2,
              "label": "Rearrange for wavelength",
              "content": "Use λ = v / f:",
              "equation": "λ = (3 × 10⁸) / (1 × 10⁸)",
              "markSchemeNote": "1 mark: correct substitution"
            },
            {
              "stepNum": 3,
              "label": "Calculate",
              "content": "Divide:",
              "equation": "λ = 3 m",
              "markSchemeNote": "1 mark: correct answer + unit"
            }
          ],
          "finalAnswer": "3 m",
          "finalAnswerUnit": "m",
          "totalMarks": 3
        },
        "edexcel": {
          "source": "Edexcel 2022 Paper 1 · Q7(a)",
          "year": 2022,
          "paper": 1,
          "questionNumber": "7(a)",
          "marks": 3,
          "questionText": "Green light has a wavelength of 550 nm. Calculate its frequency. (Speed of light = 3 × 10⁸ m/s)",
          "steps": [
            {
              "stepNum": 1,
              "label": "Convert units",
              "content": "550 nm = 550 × 10⁻⁹ m = 5.5 × 10⁻⁷ m",
              "equation": null,
              "markSchemeNote": "1 mark: correct conversion"
            },
            {
              "stepNum": 2,
              "label": "Rearrange and calculate",
              "content": "f = v / λ:",
              "equation": "f = (3 × 10⁸) / (5.5 × 10⁻⁷) = 5.45 × 10¹⁴ Hz",
              "markSchemeNote": "1 mark: substitution; 1 mark: correct answer"
            }
          ],
          "finalAnswer": "5.45 × 10¹⁴ Hz",
          "finalAnswerUnit": "Hz",
          "totalMarks": 3
