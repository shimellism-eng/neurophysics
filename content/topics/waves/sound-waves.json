      "workedExamples": {
        "aqa": {
          "source": "AQA 2023 Paper 2 · Q7(a)",
          "year": 2023,
          "paper": 2,
          "questionNumber": "7(a)",
          "marks": 3,
          "questionText": "A sound wave has a frequency of 680 Hz. The speed of sound in air is 340 m/s. Calculate the wavelength.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Write the equation",
              "content": "Use the wave equation:",
              "equation": "v = f × λ",
              "markSchemeNote": "1 mark: correct equation"
            },
            {
              "stepNum": 2,
              "label": "Rearrange for wavelength",
              "content": "Divide both sides by f:",
              "equation": "λ = v / f",
              "markSchemeNote": "1 mark: correct rearrangement"
            },
            {
              "stepNum": 3,
              "label": "Substitute and calculate",
              "content": "Put in the values:",
              "equation": "λ = 340 / 680 = 0.5 m",
              "markSchemeNote": "1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "0.5 m",
          "finalAnswerUnit": "m",
          "totalMarks": 3
        },
        "edexcel": {
          "source": "Edexcel 2022 Paper 1 · Q6(a)",
          "year": 2022,
          "paper": 1,
          "questionNumber": "6(a)",
          "marks": 3,
          "questionText": "A student claps 50 metres from a wall and hears the echo 0.29 seconds later. Calculate the speed of sound.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Find total distance",
              "content": "The sound travels to the wall and back:\ntotal distance = 2 × 50 = 100 m",
              "equation": "d = 100 m",
              "markSchemeNote": "1 mark: doubling the distance"
            },
            {
              "stepNum": 2,
              "label": "Apply speed = distance / time",
              "content": "Use v = d / t:",
              "equation": "v = 100 / 0.29 = 345 m/s",
              "markSchemeNote": "1 mark: substitution; 1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "345 m/s",
          "finalAnswerUnit": "m/s",
          "totalMarks": 3
        },
