          "paper": 2,
          "questionNumber": "6(a)",
          "marks": 3,
          "questionText": "A sound wave has a frequency of 256 Hz and travels at 340 m/s in air. Calculate the wavelength of the sound wave.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Identify the knowns",
              "content": "frequency f = 256 Hz\nwave speed v = 340 m/s",
              "equation": null,
              "markSchemeNote": null
            },
            {
              "stepNum": 2,
              "label": "Rearrange for wavelength",
              "content": "Start with v = f × λ, then divide both sides by f:",
              "equation": "λ = v / f",
              "markSchemeNote": "1 mark: correct rearrangement"
            },
            {
              "stepNum": 3,
              "label": "Substitute and calculate",
              "content": "Put in the values:",
              "equation": "λ = 340 / 256 = 1.33 m",
              "markSchemeNote": "1 mark: substitution; 1 mark: correct answer with unit"
            }
          ],
          "finalAnswer": "1.33 m",
          "finalAnswerUnit": "m",
          "totalMarks": 3
