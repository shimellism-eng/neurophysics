    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "The Wave Equation",
      "bodyHTML": "The wave equation links <strong>wave speed</strong>, <strong>frequency</strong> and <strong>wavelength</strong>. Wave speed (v) is how fast the wave travels through the medium. It equals the number of waves per second (frequency) multiplied by the length of each wave (wavelength). This equation works for <strong>all</strong> types of waves - sound, light, water, seismic waves, etc.",
      "keyEquation": "v = f × λ",
      "diagram": {
        "type": "equation-breakdown",
        "variables": [
          {
            "symbol": "v",
            "label": "Wave speed",
            "unit": "m/s",
            "color": "cyan"
          },
          {
            "symbol": "f",
            "label": "Frequency",
            "unit": "Hz",
            "color": "purple"
          },
          {
            "symbol": "λ",
            "label": "Wavelength",
            "unit": "m",
            "color": "amber"
          }
        ],
        "relationships": [
          "Higher frequency → shorter wavelength (if speed is constant)",
          "Longer wavelength → lower frequency (if speed is constant)",
          "Speed depends on the medium, not on frequency or wavelength alone"
        ]
      },
      "keyWords": [
        "wave speed",
        "frequency",
        "wavelength",
        "hertz",
        "wave equation"
      ],
      "commonErrors": [
        "Dividing instead of multiplying (v = f × λ, not f / λ)",
        "Forgetting to convert units (e.g. cm to m, kHz to Hz)",
        "Confusing wave speed with frequency"
      ],
      "keyEquationTex": "v = f\\lambda"
