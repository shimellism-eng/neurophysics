      "id": "diagnostic",
      "type": "diagnostic",
      "uiTag": "Misconception check",
      "uiColor": "red",
      "title": "Quick question first…",
      "question": "If you increase the amplitude of a wave, what happens to its speed?",
      "options": [
        "The wave speeds up",
        "The wave slows down",
        "The speed stays the same",
        "It depends on the frequency"
      ],
      "correctIndex": 2,
      "misconceptionFeedback": "⚠️ Common misconception! A bigger amplitude means the wave carries more energy, but it does NOT change the speed. Wave speed depends on the medium (and frequency × wavelength), not on amplitude.",
      "correctFeedback": "✓ Correct! Amplitude affects energy, not speed. A louder sound has a bigger amplitude but travels at the same speed as a quiet one in the same medium.",
      "bestSource": "BEST resource: GCSE Physics specification: wave properties and definitions"
    },
    {
      "id": "concept",
      "type": "concept",
      "uiTag": "Concept",
      "uiColor": "blue",
      "title": "Wave Properties",
      "svgDiagram": "wave-diagram",
      "bodyHTML": "<strong>Amplitude</strong> is the maximum displacement from the rest position: it tells you how much energy the wave carries. <strong>Wavelength (λ)</strong> is the distance from one point on a wave to the same point on the next wave (e.g. crest to crest). <strong>Frequency (f)</strong> is the number of complete waves passing a point per second, measured in <strong>hertz (Hz)</strong>. <strong>Period (T)</strong> is the time for one complete wave to pass a point. Frequency and period are inversely related: <strong>f = 1/T</strong>.",
      "keyEquation": "f = 1/T",
      "diagram": {
        "type": "equation-breakdown",
        "variables": [
          {
            "symbol": "A",
            "label": "Amplitude",
            "unit": "m",
            "color": "cyan"
          },
          {
            "symbol": "λ",
            "label": "Wavelength",
            "unit": "m",
            "color": "purple"
          },
          {
            "symbol": "f",
            "label": "Frequency",
            "unit": "Hz",
            "color": "amber"
          },
          {
            "symbol": "T",
            "label": "Period",
            "unit": "s",
            "color": "pink"
          }
        ],
        "relationships": [
          "Bigger amplitude → more energy (not faster)",
          "Higher frequency → shorter period",
          "f = 1/T and T = 1/f"
        ]
      },
      "keyWords": [
        "amplitude",
        "wavelength",
        "frequency",
        "period",
        "hertz",
        "displacement"
      ],
      "commonErrors": [
        "Measuring amplitude from crest to trough instead of from the rest position",
        "Thinking bigger amplitude means faster wave speed",
        "Confusing frequency (waves per second) with period (seconds per wave)"
      ],
      "keyEquationTex": "f = \\frac{1}{T}"
    },
