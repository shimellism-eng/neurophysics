          "year": 2023,
          "paper": 1,
          "questionNumber": "3(a)",
          "marks": 3,
          "questionText": "A student observes 20 waves passing a point in 10 seconds. Calculate the frequency and the period of the waves.",
          "steps": [
            {
              "stepNum": 1,
              "label": "Calculate frequency",
              "content": "Frequency = number of waves / time:",
              "equation": "f = 20 / 10 = 2 Hz",
              "markSchemeNote": "1 mark: correct frequency"
            },
            {
              "stepNum": 2,
              "label": "Calculate period",
              "content": "Period is the inverse of frequency:",
              "equation": "T = 1/f = 1/2 = 0.5 s",
              "markSchemeNote": "1 mark: correct period; 1 mark: both units stated"
            }
          ],
          "finalAnswer": "f = 2 Hz, T = 0.5 s",
          "finalAnswerUnit": "Hz / s",
          "totalMarks": 3
